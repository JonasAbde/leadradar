# LeadRadar Environment Configuration
# Copy this to .env and fill in values. NEVER commit .env to version control.

# ============================================
# REQUIRED
# ============================================
# Secret key for JWT signing. Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ============================================
# DATABASE
# ============================================
# SQLite path (relative to project root)
DATABASE_URL=sqlite:///./data/leadradar.db

# For PostgreSQL (future): DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/leadradar

# ============================================
# SERVER
# ============================================
# Set to 'true' when running behind HTTPS reverse proxy
HTTPS_ENABLED=false

# Public base URL for emails, Stripe callbacks, and redirects
PUBLIC_BASE_URL=http://localhost:8000

# ============================================
# STRIPE (leave blank until account is set up)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ============================================
# SMTP (email delivery)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# EMAIL "FROM" ADDRESS
# ============================================
FROM_EMAIL=noreply@leadradar.dk
