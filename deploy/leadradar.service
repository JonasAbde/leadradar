[Unit]
Description=LeadRadar FastAPI Application
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/leadradar
Environment=PATH=/home/ubuntu/leadradar/venv/bin
EnvironmentFile=/home/ubuntu/leadradar/.env
ExecStart=/home/ubuntu/leadradar/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
